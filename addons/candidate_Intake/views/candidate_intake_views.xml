<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- 1. LIST/TREE VIEW -->
    <record id="view_hr_candidate_intake_tree" model="ir.ui.view">
        <field name="name">hr.candidate.intake.tree</field>
        <field name="model">hr.candidate.intake</field>
        <field name="arch" type="xml">
            <tree string="Candidate Intake Pipeline">
                <field name="name"/>
                <field name="job_id"/>
                <field name="source"/>
                <field name="status" widget="badge" 
                       decoration-info="status == 'review'" 
                       decoration-success="status == 'approved'" 
                       decoration-danger="status == 'rejected'"/>
            </tree>
        </field>
    </record>

    <!-- 2. FORM VIEW (With State Machine Buttons) -->
    <record id="view_hr_candidate_intake_form" model="ir.ui.view">
        <field name="name">hr.candidate.intake.form</field>
        <field name="model">hr.candidate.intake</field>
        <field name="arch" type="xml">
            <form string="Candidate Intake">
                <header>
                    <button name="action_analyze_resume" string="Run AI Analysis" type="object" class="oe_highlight" icon="fa-magic"/>
                    <button name="action_start_review" string="Start Review" type="object" class="oe_highlight" invisible="status != 'new'"/>
                    
                    <button name="action_approve" string="Approve &amp; Convert" type="object" class="oe_highlight" invisible="status != 'review'" groups="candidate_Intake.group_intake_manager"/>
                    
                    <button name="action_reject" string="Reject" type="object" invisible="status != 'review'"/>
                    <field name="status" widget="statusbar" statusbar_visible="new,review,approved,rejected"/>
                </header>
                <sheet>
                    <!-- Display the AI score prominently at the top right -->
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" icon="fa-star">
                            <div class="o_stat_info">
                                <span class="o_stat_value"><field name="ai_score"/>/100</span>
                                <span class="o_stat_text">AI Match</span>
                            </div>
                        </button>
                    </div>
                    <group>
                        <group id="left_column">
                            <field name="name"/>
                            <field name="email"/>
                            <field name="phone"/>
                            <field name="linkedin_url" widget="url"/>
                            <field name="degree"/>
                        </group>
                        <group id="right_column">
                            <field name="job_id"/>
                            <field name="source"/>
                            <field name="applicant_id" invisible="not applicant_id"/>
                            <field name="resume_filename" invisible="1"/>
                            <field name="resume_file" filename="resume_filename" widget="binary"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Resume &amp; AI Analysis" name="ai_analysis">
                            <group>
                                <field name="resume_text" placeholder="Paste the candidate's plain text resume here..."/>
                                <field name="ai_summary"/>
                                <field name="ai_strengths"/>
                                <field name="ai_missing_skills"/>
                            </group>
                        </page>
                        <page string="Reviewer Notes" name="notes">
                            <field name="notes" placeholder="Add custom notes here..."/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- 3. ACTION AND WINDOW TO CONNECT MENU -->
    <record id="action_hr_candidate_intake" model="ir.actions.act_window">
        <field name="name">Candidate Intake</field>
        <field name="res_model">hr.candidate.intake</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first candidate intake record!
            </p>
        </field>
    </record>

    <!-- 4. MENU ITEMS -->
    <menuitem id="menu_hr_candidate_intake"
              name="Candidate Intake"
              parent="hr_recruitment.menu_hr_recruitment_root"
              action="action_hr_candidate_intake"
              sequence="2"/>

</odoo>